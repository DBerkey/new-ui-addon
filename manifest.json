{
  "manifest_version": 3,
  "name": "Ui-Addon Notch",
  "version": "3.0.0",
  "description": "Enhanced UI-Addon modifications by Notch",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://demonicscans.org/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://demonicscans.org/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["config.json"],
      "matches": ["https://demonicscans.org/*"]
    }
  ]
}
